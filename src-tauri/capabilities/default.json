{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Salafi Video Hub",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-meta",
    "fs:allow-appcache-read",
    "fs:allow-appcache-write",
    "fs:allow-appcache-meta",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-applocaldata-meta",
    "fs:allow-applog-read",
    "fs:allow-applog-write",
    "fs:allow-applog-meta",
    "notification:default",
    "os:default",
    "process:default",
    "updater:default",
    "shell:allow-open"
  ]
}
